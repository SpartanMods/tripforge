# Supabase — get these from your Supabase project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Amadeus — https://developers.amadeus.com (free sandbox available)
VITE_AMADEUS_API_KEY=
VITE_AMADEUS_API_SECRET=

# RapidAPI — used for Hotels.com and Airbnb scraper APIs
VITE_RAPIDAPI_KEY=

# Google Places — https://console.cloud.google.com
VITE_GOOGLE_PLACES_API_KEY=

# Anthropic / Claude — used for destination discovery AI queries
# NOTE: this key is server-side only — never expose in the browser bundle
ANTHROPIC_API_KEY=
